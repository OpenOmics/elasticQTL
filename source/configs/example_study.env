# Example config for a study (edit these paths)
BFILE="/data/studyX/genotypes_prefix"
PHENO="/data/studyX/phenotype.tsv"
PHENO_NAME="trait"
OUTDIR="/data/studyX/qtl_en_out"

COVAR="/data/studyX/covariates.tsv"
EXCLUDE="NONE"
QTL_META="NONE"

PLINK1="plink"
PLINK2="plink2"
RSCRIPT="Rscript"

GENO="0"
MIND="0"
MISSING_POLICY="error"
AUTO_IMPUTE_MAX_CELL_RATE="0.001"
AUTO_DROP_MAX_SAMPLE_RATE="0.02"

CLUMP_R2="0.2"
CLUMP_KB="500"
CLUMP_P1="1.0"
CLUMP_P2="1.0"

ALPHA="0.5"
OUTER_FOLDS="10"
INNER_FOLDS="10"
SEED="123"
P_THRESHOLDS="0.2,0.3,0.5"
LABEL_MODE="percent"

STABILITY_SET="p20"
STABILITY_MIN_FOLDS="5"

# Optional module mode (HPC)
USE_MODULES="0"
MODULE_INIT="AUTO"
MODULE_R="NONE"
MODULE_PLINK1="NONE"
MODULE_PLINK2="NONE"
