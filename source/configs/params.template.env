# ---------------------------
# REQUIRED
# ---------------------------
BFILE="/path/to/plink_prefix"            # bed/bim/fam prefix
PHENO="/path/to/phenotype.tsv"           # must include FID IID and trait col
PHENO_NAME="trait_column_name"
OUTDIR="/path/to/output_dir"

# ---------------------------
# OPTIONAL
# ---------------------------
COVAR="/path/to/covar.tsv"               # or leave empty ""
EXCLUDE="NONE"                           # or /path/to/exclude.tsv
QTL_META="NONE"                          # or /path/to/qtl_metadata.csv

# ---------------------------
# TOOLS
# ---------------------------
PLINK1="plink"
PLINK2="plink2"
RSCRIPT="Rscript"

# ---------------------------
# OPTIONAL: MODULE MANAGEMENT (HPC)
# ---------------------------
USE_MODULES="0"                         # 0|1. If 1, pipeline runs 'module load' before each step.
MODULE_INIT="AUTO"                      # AUTO (tries common init scripts) or path to modules init script
MODULE_R="NONE"                         # e.g. "R" or "R/4.3"
MODULE_PLINK1="NONE"                    # e.g. "plink/1.9" (for clumping)
MODULE_PLINK2="NONE"                    # e.g. "plink" or "plink/3.6-alpha" (for plink2)

# ---------------------------
# MISSINGNESS POLICY (NO IMPUTATION)
# ---------------------------
GENO="0"                                 # variant missingness filter (default strict)
MIND="0"                                 # sample missingness filter (default strict)
MISSING_POLICY="error"                   # error | drop_samples | mean_impute | auto
AUTO_IMPUTE_MAX_CELL_RATE="0.001"           # only used when MISSING_POLICY=auto (e.g. 0.001 = 0.1% missing cells)
AUTO_DROP_MAX_SAMPLE_RATE="0.02"            # only used when MISSING_POLICY=auto (e.g. 0.02 = 2% samples with any missing)

# ---------------------------
# CLUMP PARAMS
# ---------------------------
CLUMP_R2="0.2"
CLUMP_KB="500"
CLUMP_P1="1.0"
CLUMP_P2="1.0"

# ---------------------------
# ELASTIC NET
# ---------------------------
ALPHA="0.5"
OUTER_FOLDS="10"
INNER_FOLDS="10"
SEED="123"
P_THRESHOLDS="0.2,0.3,0.5"
LABEL_MODE="percent"                     # percent recommended (p20,p30,p50)

# ---------------------------
# STABILITY
# ---------------------------
STABILITY_SET="p20"                      # which nested set to use for stability filtering
STABILITY_MIN_FOLDS="5"
