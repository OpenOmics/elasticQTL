# ---------------------------
# VALIDATION / REFIT PIPELINE
# ---------------------------
# This config is used by: scripts/run_validation.sh

# Required: training artifacts
TRAIN_MODEL_RDS="/data/NCBR/projects/NCBR-263/2025/pipeline_testing/07_en_stable/final_EN_model_p20_stable.rds"
TRAIN_RAW="/data/NCBR/projects/NCBR-263/2025/pipeline_testing/05_genotypes/ld_variants_forEN.raw"
TRAIN_PHENO="/data/NCBR/projects/NCBR-263/2025/QTL_analysis/data/continuous/phenotype.txt"
PHENO_NAME="pyroptosis_score"

# Required: validation cohorts manifest
# Tab-delimited file with header:
# cohort    bfile
# Example:
# wgs   /data/wgs/genotypes_prefix
# wes   /data/wes/genotypes_prefix
# array /data/array/genotypes_prefix
COHORTS_TSV="/data/NCBR/projects/NCBR-263/2025/pipeline_testing/qtl_en_pipeline_new/configs/validation_cohorts.txt"

# Output directory for validation results
OUTDIR="/data/NCBR/projects/NCBR-263/2025/pipeline_testing/validation3"

# Intersection strategy for choosing refit variants
# all  = only variants available in ALL cohorts
# any  = union of variants available in ANY cohort (scores per cohort will use available subset)
# cohort:<name> = variants available in a single cohort (e.g. cohort:wgs)
INTERSECTION_MODE="all"

# Elastic net refit parameters (on TRAINING cohort)
ALPHA="0.5"
NFOLDS="10"
SEED="123"

# Missingness policy for refit + scoring
# error | drop_samples | mean_impute | auto
MISSING_POLICY="mean_impute"
AUTO_IMPUTE_MAX_CELL_RATE="0.001"
AUTO_DROP_MAX_SAMPLE_RATE="0.02"

# Ambiguous SNP handling during allele harmonization (A/T or C/G)
# drop (recommended) | keep
AMBIGUOUS_POLICY="drop"

# Tools
PLINK2="plink2"
RSCRIPT="Rscript"

# Optional module management (Biowulf/HPC)
USE_MODULES="1"
MODULE_INIT="AUTO"
MODULE_R="R"
MODULE_PLINK2="plink/2.3-alpha"
# (PLINK1 not needed for validation steps)
