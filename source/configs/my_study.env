# ---------------------------
# REQUIRED
# ---------------------------
BFILE="/data/NCBR/projects/NCBR-263/2025/newest/merge_new_final_pyroptosis"            # bed/bim/fam prefix
PHENO="/data/NCBR/projects/NCBR-263/2025/QTL_analysis/data/continuous/phenotype.txt"           # must include FID IID and trait col
PHENO_NAME="pyroptosis_score"
OUTDIR="output"

# ---------------------------
# OPTIONAL
# ---------------------------
COVAR="/data/NCBR/projects/NCBR-263/2025/QTL_analysis/data/covariates_clean.txt"               # or leave empty ""
EXCLUDE="/data/NCBR/projects/NCBR-263/2025/QTL_analysis/data/continuous/exclude.txt"                           # or /path/to/exclude.tsv
QTL_META="/data/NCBR/projects/NCBR-263/2025/QTL_analysis/continuous/bidirectional_new/pyroptosis_qtl_metadata_new.csv"                          # or /path/to/qtl_metadata.csv

# ---------------------------
# TOOLS
# ---------------------------
PLINK1="plink"
PLINK2="plink2"
RSCRIPT="Rscript"

# ---------------------------
# OPTIONAL: MODULE MANAGEMENT (HPC)
# ---------------------------
# Enable module switching inside the pipeline
USE_MODULES="1"
MODULE_INIT="AUTO"

# R module
MODULE_R="R"

# PLINK modules (pin versions for reproducibility)
MODULE_PLINK1="plink/1.9.0-beta4.4"   # for clumping step (plink 1.9)
MODULE_PLINK2="plink/2.3-alpha"       # for plink2 steps (assoc/export)

# Commands (after module load these should exist)
PLINK1="plink"
PLINK2="plink2"
RSCRIPT="Rscript"
# ---------------------------
# MISSINGNESS POLICY (NO IMPUTATION)
# ---------------------------
GENO="0"                                 # variant missingness filter (default strict)
MIND="0"                                 # sample missingness filter (default strict)
MISSING_POLICY="error"                   # error | drop_samples | mean_impute | auto
AUTO_IMPUTE_MAX_CELL_RATE="0.001"           # only used when MISSING_POLICY=auto (e.g. 0.001 = 0.1% missing cells)
AUTO_DROP_MAX_SAMPLE_RATE="0.02"            # only used when MISSING_POLICY=auto (e.g. 0.02 = 2% samples with any missing)

# ---------------------------
# CLUMP PARAMS
# ---------------------------
CLUMP_R2="0.2"
CLUMP_KB="500"
CLUMP_P1="1.0"
CLUMP_P2="1.0"

# ---------------------------
# ELASTIC NET
# ---------------------------
ALPHA="0.5"
OUTER_FOLDS="10"
INNER_FOLDS="10"
SEED="123"
P_THRESHOLDS="0.2,0.3,0.5"
LABEL_MODE="percent"                     # percent recommended (p20,p30,p50)

# ---------------------------
# STABILITY
# ---------------------------
STABILITY_SET="p20"                      # which nested set to use for stability filtering
STABILITY_MIN_FOLDS="5"
